# GitHub PAT for gh CLI and GitHub MCP (issues, PRs). Fine-grained or classic with repo scope.
GITHUB_TOKEN=your_github_pat

# Gemini API key for resume matching and outreach generation
GEMINI_API_KEY=your_gemini_api_key
# Antigravity API key (same as Gemini API key for now)
AV_API_KEY=your_gemini_api_key
ANTIGRAVITY_API_KEY=your_gemini_api_key
# Optional: Gemini model name (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-3.1-pro-preview

# BrightData credentials for job scraping
BRIGHTDATA_API_KEY=your_brightdata_api_key
BRIGHTDATA_JOB_SCRAPER_ID=your_brightdata_job_scraper_id

# Apify credentials for outreach contact scraping
APIFY_API_TOKEN=your_apify_api_token
