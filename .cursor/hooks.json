{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "python3 scripts/hooks/db_safety_gate.py",
        "failClosed": true
      }
    ],
    "preToolUse": [
      {
        "command": "python3 scripts/hooks/db_safety_gate.py",
        "matcher": "Delete|Write",
        "failClosed": true
      }
    ]
  }
}
